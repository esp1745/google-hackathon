# Google API Key for Gemini
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Google Cloud credentials for Text-to-Speech
# If using TTS, set up a service account and download JSON key
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Google Cloud Project ID for Vertex AI (Veo 3.1 Video + Imagen 3 Images)
# Required for real AI-generated videos and images
# Get from: https://console.cloud.google.com
GOOGLE_CLOUD_PROJECT_ID=your_project_id_here
